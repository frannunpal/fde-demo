{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run copy-docs && vite",
    "copy-docs": "mkdir -p public/Documents && cp docs/*.md public/Documents/ 2>/dev/null; for d in docs/*/; do subdir=\"public/Documents/$(basename $d)\"; mkdir -p \"$subdir\" && cp \"$d\"*.md \"$subdir/\" 2>/dev/null; done; true"
  },
  "dependencies": {
    "@fde-desktop/fde-core": "^0.4.22",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@types/bun": "latest",
    "storybook": "10.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "6.4.2",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitest": "^4.1.4"
  }
}
