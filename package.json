{
  "name": "bun-react-template",
  "version": "0.4.35",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run copy-docs && bunx --bun vite",
    "copy-docs": "mkdir -p public/Documents && cp docs/*.md public/Documents/ 2>/dev/null; for d in docs/*/; do subdir=\"public/Documents/$(basename $d)\"; mkdir -p \"$subdir\" && cp \"$d\"*.md \"$subdir/\" 2>/dev/null; done; true",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/"
  },
  "dependencies": {
    "@fde-desktop/fde-core": "0.4.47",
    "@gfazioli/mantine-depth-select": "^2.0.0",
    "@mantine/charts": "^9.1.0",
    "@mantine/core": "^9.1.0",
    "@mantine/dates": "^9.1.0",
    "@tanstack/react-query": "^5.100.1",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@types/bun": "latest",
    "storybook": "10.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitest": "^4.1.5"
  }
}
